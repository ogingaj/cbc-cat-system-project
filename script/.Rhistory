plot(model_2pl, type = "info",      main = "Test Information Curve вЂ” Aptitude")
# Standard Error Curve
# Inverse of information вЂ” shows measurement precision across theta levels
plot(model_2pl, type = "SE",        main = "Standard Error Curve вЂ” Aptitude")
## =============================================================================
# STAGE 2: PERSONALITY вЂ” GRADED RESPONSE MODEL (GRM)
# =============================================================================
# в”Ђв”Ђ 1. Prep data в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
pers_matrix <- as.matrix(personality_items)
# в”Ђв”Ђ 2. Fit GRM в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
model_open <- mirt(as.matrix(personality_items %>% select(all_of(open_items))), 1, itemtype = "graded")
model_cons <- mirt(as.matrix(personality_items %>% select(all_of(cons_items))), 1, itemtype = "graded")
model_extr <- mirt(as.matrix(personality_items %>% select(all_of(extr_items))), 1, itemtype = "graded")
model_agre <- mirt(as.matrix(personality_items %>% select(all_of(agre_items))), 1, itemtype = "graded")
model_neur <- mirt(as.matrix(personality_items %>% select(all_of(neur_items))), 1, itemtype = "graded")
# в”Ђв”Ђ 3. Check model fit в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# polytomous tables regardless of subscale size
itemfit(model_open)
itemfit(model_cons)
itemfit(model_extr)
itemfit(model_agre)
itemfit(model_neur)
# в”Ђв”Ђ 4. Extract item parameters в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
coef(model_open, IRTpars = TRUE, simplify = TRUE)$items
coef(model_cons, IRTpars = TRUE, simplify = TRUE)$items
coef(model_extr, IRTpars = TRUE, simplify = TRUE)$items
coef(model_agre, IRTpars = TRUE, simplify = TRUE)$items
coef(model_neur, IRTpars = TRUE, simplify = TRUE)$items
# в”Ђв”Ђ 5. Estimate trait scores в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
scores_open <- fscores(model_open, full.scores.SE = TRUE)
scores_cons <- fscores(model_cons, full.scores.SE = TRUE)
scores_extr <- fscores(model_extr, full.scores.SE = TRUE)
scores_agre <- fscores(model_agre, full.scores.SE = TRUE)
scores_neur <- fscores(model_neur, full.scores.SE = TRUE)
# в”Ђв”Ђ 6. Save trait scores with student IDs в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
trait_df <- data.frame(
student_id        = personality$student_id,
openness          = scores_open[, 1],
conscientiousness = scores_cons[, 1],
extraversion      = scores_extr[, 1],
agreeableness     = scores_agre[, 1],
neuroticism       = scores_neur[, 1]
)
print(head(trait_df))
# в”Ђв”Ђ 7. Save standard errors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
se_df <- data.frame(
student_id           = personality$student_id,
se_openness          = scores_open[, 2],
se_conscientiousness = scores_cons[, 2],
se_extraversion      = scores_extr[, 2],
se_agreeableness     = scores_agre[, 2],
se_neuroticism       = scores_neur[, 2]
)
print(head(se_df))
# ICC for GRM: shows probability of each response category (1вЂ“5) across theta
# Each item produces 5 curves вЂ” one per response category
plot(model_open, type = "trace",     main = "ICC вЂ” Openness")
plot(model_open, type = "infotrace", main = "IIC вЂ” Openness")
plot(model_cons, type = "trace",     main = "ICC вЂ” Conscientiousness")
plot(model_cons, type = "infotrace", main = "IIC вЂ” Conscientiousness")
plot(model_extr, type = "trace",     main = "ICC вЂ” Extraversion")
plot(model_extr, type = "infotrace", main = "IIC вЂ” Extraversion")
plot(model_agre, type = "trace",     main = "ICC вЂ” Agreeableness")
plot(model_agre, type = "infotrace", main = "IIC вЂ” Agreeableness")
plot(model_neur, type = "trace",     main = "ICC вЂ” Neuroticism")
plot(model_neur, type = "infotrace", main = "IIC вЂ” Neuroticism")
# =============================================================================
# STEP 5: CAT ENGINE
# Max Fisher information item selection | EAP ability updating | SE < 0.30 stop
# =============================================================================
run_cat <- function(model, response_vector, max_items = 10, se_stop = 0.30) {
# в”Ђв”Ђ initialise tracking vectors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
all_items     <- colnames(response_vector)
administered  <- c()
responses     <- c()
theta_history <- c()
se_history    <- c()
# starting values: theta = 0 (centre of scale), SE = unknown
theta_est <- 0
se_est    <- NA
# extract item parameters once вЂ” reused at every step
params <- coef(model, IRTpars = TRUE, simplify = TRUE)$items
for (i in 1:max_items) {
# в”Ђв”Ђ item selection в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# first item: pick closest b to 0 вЂ” medium difficulty as neutral start
if (i == 1) {
next_item <- rownames(params)[which.min(abs(params[, "b"]))]
} else {
# subsequent items: maximum Fisher information at current theta
unused_items <- setdiff(all_items, administered)
info_values <- sapply(unused_items, function(item) {
item_index <- which(all_items == item)
# Theta must be a matrix for iteminfo() вЂ” not a bare scalar
iteminfo(extract.item(model, item_index),
Theta = matrix(theta_est, ncol = 1))
})
next_item <- unused_items[which.max(info_values)]
}
# в”Ђв”Ђ administer item в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
administered <- c(administered, next_item)
responses    <- c(responses, as.numeric(response_vector[[next_item]]))
# в”Ђв”Ђ build response pattern в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# fscores() needs a full-length vector вЂ” NA for unadministered items
pattern        <- rep(NA, length(all_items))
names(pattern) <- all_items
pattern[administered] <- responses
# в”Ђв”Ђ update theta в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# EAP preferred over MLE вЂ” MLE returns В±Inf on all-correct/all-incorrect
# patterns early in the test, EAP stays bounded throughout
score <- fscores(
model,
response.pattern = matrix(pattern, nrow = 1),
method           = "EAP",
full.scores.SE   = TRUE
)
theta_est <- score[1, 1]
se_est    <- score[1, 2]
theta_history <- c(theta_history, theta_est)
se_history    <- c(se_history,    se_est)
# в”Ђв”Ђ stopping rule в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# stop early if SE drops below 0.30 вЂ” equivalent to information > 11.1
if (!is.na(se_est) && se_est < se_stop) break
}
# в”Ђв”Ђ return results в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
data.frame(
step     = 1:length(administered),
item     = administered,
response = responses,
theta    = theta_history,
SE       = se_history
)
}
# в”Ђв”Ђ run CAT for student 1 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
student1   <- aptitude_items[1, , drop = FALSE]
cat_result <- run_cat(model_2pl, student1, max_items = 10, se_stop = 0.30)
cat_result
#three example students
#compute total score for each student
scores <- rowSums(aptitude_items)
#identify low, middle, and high student abaility
low_id <- which.min(scores)
high_id <- which.max(scores)
mid_id <- which.min(abs(scores - mean(scores)))
#run Cat for each selected student
cat_low  <- run_cat(model_2pl, aptitude_items[low_id, , drop = FALSE])
cat_mid  <- run_cat(model_2pl, aptitude_items[mid_id, , drop = FALSE])
cat_high <- run_cat(model_2pl, aptitude_items[high_id, , drop = FALSE])
#show results
print(cat_low)
print(cat_mid)
print(cat_high)
#compare final ability
cat_low$theta[nrow(cat_low)]
cat_mid$theta[nrow(cat_mid)]
cat_high$theta[nrow(cat_high)]
#summary table
data.frame(
student = c("Low", "Mid", "High"),
final_theta = c(
tail(cat_low$theta, 1),
tail(cat_mid$theta, 1),
tail(cat_high$theta, 1)
),
final_SE = c(
tail(cat_low$SE, 1),
tail(cat_mid$SE, 1),
tail(cat_high$SE, 1)
)
)
# =============================================================================
# STEP 7: CAT VISUALISATION
# Per step: ОёМ‚ + SE trajectory | item selection rationale | ICC + IIC
# =============================================================================
library(ggplot2)
# в”Ђв”Ђ 1. Verbose version of run_cat вЂ” saves info snapshots at every step в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Needed so we can show WHY each item was selected at each step
run_cat_verbose <- function(model, response_vector, max_items = 10, se_stop = 0.30) {
all_items          <- colnames(response_vector)
administered       <- c()
responses          <- c()
theta_history      <- c()
se_history         <- c()
info_snapshots     <- list()   # info for ALL remaining items at each step
theta_at_selection <- c()      # theta value used for selection at each step
theta_est <- 0
se_est    <- NA
params <- coef(model, IRTpars = TRUE, simplify = TRUE)$items
for (i in 1:max_items) {
# record theta used for this selection step
theta_at_selection <- c(theta_at_selection, theta_est)
unused_items       <- setdiff(all_items, administered)
# compute info for all remaining items at current theta
info_vals <- sapply(unused_items, function(item) {
idx <- which(all_items == item)
iteminfo(extract.item(model, idx), Theta = matrix(theta_est, ncol = 1))
})
names(info_vals) <- unused_items
info_snapshots[[i]] <- info_vals
# step 1: b closest to 0 | step 2+: max Fisher information
if (i == 1) {
next_item <- rownames(params)[which.min(abs(params[, "b"]))]
} else {
next_item <- unused_items[which.max(info_vals)]
}
# administer item
administered <- c(administered, next_item)
responses    <- c(responses, as.numeric(response_vector[[next_item]]))
# full response pattern with NA for unadministered items
pattern        <- rep(NA, length(all_items))
names(pattern) <- all_items
pattern[administered] <- responses
# update theta via EAP
score <- fscores(
model,
response.pattern = matrix(pattern, nrow = 1),
method           = "EAP",
full.scores.SE   = TRUE
)
theta_est <- score[1, 1]
se_est    <- score[1, 2]
theta_history <- c(theta_history, theta_est)
se_history    <- c(se_history,    se_est)
if (!is.na(se_est) && se_est < se_stop) break
}
list(
result             = data.frame(
step     = 1:length(administered),
item     = administered,
response = responses,
theta    = theta_history,
SE       = se_history
),
info_snapshots     = info_snapshots,
theta_at_selection = theta_at_selection
)
}
# в”Ђв”Ђ 2. ОёМ‚ trajectory plot with SE ribbon в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
plot_theta_trajectory <- function(verbose_result, student_label = "Student") {
df <- verbose_result$result
ggplot(df, aes(x = step)) +
geom_ribbon(aes(ymin = theta - SE, ymax = theta + SE),
fill = "steelblue", alpha = 0.2) +
geom_line(aes(y = theta), colour = "steelblue", linewidth = 1) +
geom_point(aes(y = theta), colour = "steelblue", size = 3) +
geom_hline(yintercept = 0, linetype = "dashed", colour = "grey50") +
geom_label(aes(y = theta, label = round(theta, 2)), vjust = -0.8, size = 3) +
scale_x_continuous(breaks = df$step) +
labs(
title    = paste("Ability Estimation Trajectory вЂ”", student_label),
subtitle = paste0(
"Final ОёМ‚ = ", round(tail(df$theta, 1), 3),
"  |  Final SE = ", round(tail(df$SE, 1), 3),
"  |  Items administered: ", nrow(df)
),
x = "CAT Step",
y = "Estimated Ability (ОёМ‚)"
) +
theme_minimal()
}
# в”Ђв”Ђ 3. Item selection rationale вЂ” bar chart of all info at current Оё в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# The selected item (red bar) has the highest Fisher information вЂ” that is why
# it was chosen. Step 1 uses b-proximity instead of max info, noted in subtitle.
plot_item_selection <- function(verbose_result, step, student_label = "Student") {
info_vals  <- verbose_result$info_snapshots[[step]]
selected   <- verbose_result$result$item[step]
theta_used <- verbose_result$theta_at_selection[step]
df <- data.frame(
item     = names(info_vals),
info     = as.numeric(info_vals),
selected = names(info_vals) == selected
)
df <- df[order(df$info, decreasing = TRUE), ]
df$item <- factor(df$item, levels = df$item)
subtitle <- if (step == 1) {
paste0("Step 1: item with b closest to ОёМ‚ = 0 selected as neutral start (", selected, ")")
} else {
paste0("ОёМ‚ = ", round(theta_used, 3),
" | ", selected, " has highest Fisher information вЂ” selected next")
}
ggplot(df, aes(x = item, y = info, fill = selected)) +
geom_col() +
scale_fill_manual(
values = c("FALSE" = "grey75", "TRUE" = "firebrick"),
labels = c("Not selected", "Selected"),
name   = NULL
) +
labs(
title    = paste0(student_label, " вЂ” Step ", step, ": Item Selection Rationale"),
subtitle = subtitle,
x        = "Item",
y        = paste0("Fisher Information at Оё = ", round(theta_used, 3))
) +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
}
# в”Ђв”Ђ 4. ICC and IIC for the item selected at a given step в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
plot_item_curves <- function(model, verbose_result, step,
student_label = "Student", all_item_names) {
item_name <- verbose_result$result$item[step]
item_idx  <- which(all_item_names == item_name)
# ICC вЂ” probability of correct response across theta
plot(model, which.items = item_idx, type = "trace",
main = paste0(student_label, " вЂ” Step ", step, " | ICC: ", item_name))
# IIC вЂ” Fisher information across theta
plot(model, which.items = item_idx, type = "infotrace",
main = paste0(student_label, " вЂ” Step ", step, " | IIC: ", item_name))
}
# =============================================================================
# RUN VERBOSE CAT FOR THREE STUDENTS
# =============================================================================
verb_low  <- run_cat_verbose(model_2pl, aptitude_items[low_id,  , drop = FALSE])
verb_mid  <- run_cat_verbose(model_2pl, aptitude_items[mid_id,  , drop = FALSE])
verb_high <- run_cat_verbose(model_2pl, aptitude_items[high_id, , drop = FALSE])
# =============================================================================
# GENERATE ALL PLOTS
# =============================================================================
all_item_names <- colnames(aptitude_items)
for (student in list(
list(res = verb_low,  label = "Low Ability"),
list(res = verb_mid,  label = "Mid Ability"),
list(res = verb_high, label = "High Ability")
)) {
# в”Ђв”Ђ summary в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
cat("\n==========", student$label, "==========\n")
cat("Items administered: ", nrow(student$res$result), "\n")
cat("Final ОёМ‚:           ", round(tail(student$res$result$theta, 1), 3), "\n")
cat("Final SE:           ", round(tail(student$res$result$SE,    1), 3), "\n")
print(student$res$result)
# в”Ђв”Ђ Оё trajectory в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
print(plot_theta_trajectory(student$res, student$label))
# в”Ђв”Ђ per step: selection rationale + ICC + IIC в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
for (s in 1:nrow(student$res$result)) {
print(plot_item_selection(student$res, s, student$label))
plot_item_curves(model_2pl, student$res, s, student$label, all_item_names)
}
}
