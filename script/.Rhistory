recommend_pathway_full <- function(cat_result, trait_scores, mapping_table,
apt_weight  = 0.70, pers_weight = 0.30,
item_params = NULL) {
# в”Ђв”Ђ aptitude score per pathway в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# If item_params is provided: use IRT expected score across ALL domain items
# given final ОёМ‚ вЂ” this is fairer than proportion correct on administered items
# because it accounts for item difficulty properly across all three domains.
# Fallback: proportion correct on administered items (original logic)
if (!is.null(item_params)) {
# final theta estimate from the CAT session
theta_hat <- tail(cat_result$theta, 1)
# 2PL probability: P(correct | Оё, a, b) = 1 / (1 + exp(в€’a Г— (Оё в€’ b)))
item_params$p_correct <- 1 / (1 + exp(-item_params$a * (theta_hat - item_params$b)))
# average expected score across all items in each domain
stem_ip   <- item_params[item_params$pathway == "STEM", ]
social_ip <- item_params[item_params$pathway == "Social Sciences", ]
arts_ip   <- item_params[item_params$pathway == "Arts & Sports", ]
apt_stem   <- if (nrow(stem_ip)   > 0) mean(stem_ip$p_correct)   else 0
apt_social <- if (nrow(social_ip) > 0) mean(social_ip$p_correct) else 0
apt_arts   <- if (nrow(arts_ip)   > 0) mean(arts_ip$p_correct)   else 0
} else {
# в”Ђв”Ђ fallback: proportion correct on administered items в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
df <- merge(cat_result, mapping_table, by.x = "item", by.y = "Item ID")
n_stem   <- sum(df$`Pathway Signal` == "STEM")
n_social <- sum(df$`Pathway Signal` == "Social Sciences")
n_arts   <- sum(df$`Pathway Signal` == "Arts & Sports")
apt_stem   <- if (n_stem   > 0) sum(df$response[df$`Pathway Signal` == "STEM"])             / n_stem   else 0
apt_social <- if (n_social > 0) sum(df$response[df$`Pathway Signal` == "Social Sciences"])  / n_social else 0
apt_arts   <- if (n_arts   > 0) sum(df$response[df$`Pathway Signal` == "Arts & Sports"])    / n_arts   else 0
}
# в”Ђв”Ђ personality fit score per pathway в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
O <- trait_scores$openness
C <- trait_scores$conscientiousness
E <- trait_scores$extraversion
A <- trait_scores$agreeableness
N <- trait_scores$neuroticism
pers_stem   <- 0.5 * C + 0.5 * O
pers_social <- 0.4 * A + 0.3 * E + 0.3 * O
pers_arts   <- 0.5 * O + 0.3 * E + 0.2 * (1 - abs(N))
# в”Ђв”Ђ rescale personality scores to 0вЂ“1 в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
pers_all   <- c(pers_stem, pers_social, pers_arts)
pers_range <- max(pers_all) - min(pers_all)
if (pers_range > 0) {
pers_stem   <- (pers_stem   - min(pers_all)) / pers_range
pers_social <- (pers_social - min(pers_all)) / pers_range
pers_arts   <- (pers_arts   - min(pers_all)) / pers_range
}
# в”Ђв”Ђ weighted composite в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
final_stem   <- apt_weight * apt_stem   + pers_weight * pers_stem
final_social <- apt_weight * apt_social + pers_weight * pers_social
final_arts   <- apt_weight * apt_arts   + pers_weight * pers_arts
scores <- c(
STEM              = final_stem,
`Social Sciences` = final_social,
`Arts & Sports`   = final_arts
)
# в”Ђв”Ђ return recommendation + all score breakdowns в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
return(list(
recommendation     = names(scores)[which.max(scores)],
scores             = scores,
aptitude_scores    = c(STEM = apt_stem,   `Social Sciences` = apt_social, `Arts & Sports` = apt_arts),
personality_scores = c(STEM = pers_stem,  `Social Sciences` = pers_social, `Arts & Sports` = pers_arts)
))
}
shiny::runApp("/Users/OgingaJ/Documents/Backup data/Documents/Post_S/Spring_2026/adaptive_measurement/cat_project/script")
